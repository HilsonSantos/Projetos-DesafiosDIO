CREATE TABLE IF NOT EXISTS CARGA_VENDAS (
    ORDEM_COMPRA CHARACTER VARYING(10) NOT NULL,
    DATA DATE NOT NULL,
    SKU CHARACTER VARYING(6) NOT NULL,
    CLIENTE_ID INTEGER NOT NULL,
    QTDE_VENDIDA INTEGER NOT NULL,
    LOJA_ID INTEGER NOT NULL,
    CONSTRAINT PK_ID_CARGA_VENDAS PRIMARY KEY(ORDEM_COMPRA, SKU)
)
